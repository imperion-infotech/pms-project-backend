	<parameter name="REPORT_DATE" class="java.lang.String">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("M/d/yyyy").format(new java.util.Date())]]></defaultValueExpression>
	</parameter>
	<parameter name="PRINTED_BY" class="java.lang.String">
		<defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression>
	</parameter>
	<parameter name="FROM_DATE" class="java.sql.Date"/>
	<parameter name="TO_DATE" class="java.sql.Date"/>
	<parameter name="FLOOR_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="BUILDING_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="BUILDING_NAME" class="java.lang.String">
		<defaultValueExpression><![CDATA["All Buildings"]]></defaultValueExpression>
	</parameter>
	<parameter name="FLOOR_NAME" class="java.lang.String">
		<defaultValueExpression><![CDATA["All Floors"]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT distinct
    series.rn                AS rn,
    h.hotel_name             AS hotel_name,
    h.address                AS address,
    h.city                   AS city,
    h.state                  AS state,
    h.country                AS country,
    h.zip_code               AS zip_code,
    h.contact_number         AS contact_number,
    h.email                  AS email,
    COALESCE(r.building_name, 'All Buildings') AS current_building,
    COALESCE(r.floor_name,    'All Floors')    AS current_floor,

    -- Room name + building/floor (no room type)
    MAX(CASE WHEN r.room_status_name = 'Vacant Ready'        THEN r.room_display END) AS v_ready,
    MAX(CASE WHEN r.room_status_name = 'Occupied Clean'      THEN r.room_display END) AS o_clean,
    MAX(CASE WHEN r.room_status_name = 'Occupied Dirty'      THEN r.room_display END) AS o_dirty,
    MAX(CASE WHEN r.room_status_name = 'Vacant Dirty'        THEN r.room_display END) AS v_dirty,
    MAX(CASE WHEN r.room_status_name = 'Vacant Clean'        THEN r.room_display END) AS v_clean,
    MAX(CASE WHEN r.room_status_name = 'Vacant Maintenance'  THEN r.room_display END) AS v_maint,
    MAX(CASE WHEN r.room_status_name = 'Reserve Ready'       THEN r.room_display END) AS r_ready,

    -- Room type name as separate column per status
    MAX(CASE WHEN r.room_status_name = 'Vacant Ready'        THEN r.room_type_name END) AS v_ready_type,
    MAX(CASE WHEN r.room_status_name = 'Occupied Clean'      THEN r.room_type_name END) AS o_clean_type,
    MAX(CASE WHEN r.room_status_name = 'Occupied Dirty'      THEN r.room_type_name END) AS o_dirty_type,
    MAX(CASE WHEN r.room_status_name = 'Vacant Dirty'        THEN r.room_type_name END) AS v_dirty_type,
    MAX(CASE WHEN r.room_status_name = 'Vacant Clean'        THEN r.room_type_name END) AS v_clean_type,
    MAX(CASE WHEN r.room_status_name = 'Vacant Maintenance'  THEN r.room_type_name END) AS v_maint_type,
    MAX(CASE WHEN r.room_status_name = 'Reserve Ready'       THEN r.room_type_name END) AS r_ready_type

FROM (
    SELECT generate_series(1, COALESCE((
        SELECT MAX(cnt)
        FROM (
            SELECT COUNT(*) AS cnt
            FROM multi_motels_pms_db.room_master rm2
            JOIN multi_motels_pms_db.room_status rs2
                ON rm2.room_status_id = rs2.room_status_id
            WHERE rm2.hotel_id = $P{HOTEL_ID}
              AND rm2.is_deleted = false
              AND rm2.is_active = true
              AND rm2.room_status_id IS NOT NULL
              AND ($P{FLOOR_ID} IS NULL OR rm2.floor_id = CAST($P{FLOOR_ID} AS bigint))
              AND ($P{BUILDING_ID} IS NULL OR rm2.building_id = CAST($P{BUILDING_ID} AS bigint))
            GROUP BY rs2.room_status_name
        ) counts
    ), 1)) AS rn
) series
CROSS JOIN (
    SELECT hotel_name, address, city, state, country, zip_code, contact_number, email
    FROM multi_motels_pms_db.hotel
    WHERE id = $P{HOTEL_ID}
) h
LEFT JOIN (
    SELECT
        rm.room_name,
        rt.room_type_name,
        rs.room_status_name,
        b.building_name,
        f.floor_name,
        rm.room_name
            AS room_display,
        ROW_NUMBER() OVER (
            PARTITION BY rs.room_status_name
            ORDER BY b.building_name, f.floor_name, rm.room_name
        ) AS rn
    FROM multi_motels_pms_db.room_master rm
    JOIN multi_motels_pms_db.room_status rs
        ON rm.room_status_id = rs.room_status_id
    LEFT JOIN multi_motels_pms_db.room_type rt
        ON rm.room_type_id = rt.room_type_id
    LEFT JOIN multi_motels_pms_db.building b
        ON rm.building_id = b.building_id
       AND b.is_deleted = false
       AND b.is_active = true
    LEFT JOIN multi_motels_pms_db.floor f
        ON rm.floor_id = f.floor_id
       AND f.is_deleted = false
       AND f.is_active = true
    WHERE rm.hotel_id = $P{HOTEL_ID}
      AND rm.is_deleted = false
      AND rm.is_active = true
      AND rm.room_status_id IS NOT NULL
      AND ($P{FLOOR_ID} IS NULL OR rm.floor_id = CAST($P{FLOOR_ID} AS bigint))
      AND ($P{BUILDING_ID} IS NULL OR rm.building_id = CAST($P{BUILDING_ID} AS bigint))
) r ON r.rn = series.rn
GROUP BY
    series.rn,
    h.hotel_name, h.address, h.city, h.state,
    h.country, h.zip_code, h.contact_number, h.email,
    r.building_name, r.floor_name
ORDER BY  series.rn]]></query>
