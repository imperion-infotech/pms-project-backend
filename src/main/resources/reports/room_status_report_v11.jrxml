<jasperReport name="room_status_report" language="java" columnCount="1" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7f1ddb4f-5999-4d9b-9651-0733fab8d9a0">
