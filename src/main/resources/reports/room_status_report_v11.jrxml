	</parameter>
	<parameter name="HOTEL_STATE" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_COUNTRY" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_ZIPCODE" class="java.lang.String">
