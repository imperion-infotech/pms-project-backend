			<element kind="textField" uuid="c7aef1c1-843d-418c-bc65-a062e31822d9" x="135" y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="9.0" pattern="M/d/yy h:mm a" blankWhenNull="true" hTextAlign="Center">
