	<detail>
		<band height="14" splitType="Stretch">
			<element kind="textField" uuid="b7dbc416-48b9-4ded-9e5a-85f259e27969" x="0" y="0" width="55" height="13" fontName="DejaVu Sans" fontSize="7.0" blankWhenNull="true" hTextAlign="Center">
				<expression><![CDATA[
                    "CheckIn".equals($F{guest_status})    ? "C/I" :
                    "Check-In".equals($F{guest_status})   ? "C/I" :
                    "Check-Out".equals($F{guest_status})  ? "P-C/I" :
                    "Reservation".equals($F{guest_status})? "R/B" :
                    "Occupied".equals($F{guest_status})   ? "G/P" :
                    "Cancelled".equals($F{guest_status})  ? "Cancelled" :
                    ($F{guest_status} != null ? $F{guest_status} : "")
                ]]></expression>
			</element>
			<element kind="textField" uuid="f109b06b-0eb1-461a-9927-92a973434473" x="55" y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="9.0" pattern="MM/dd" blankWhenNull="true" hTextAlign="Center">
				<expression><![CDATA[$F{date_in}]]></expression>
			</element>
			<element kind="textField" uuid="8708765d-0181-496f-b782-e7ee1e2684d0" x="95" y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="9.0" pattern="MM/dd" blankWhenNull="true" hTextAlign="Center">
