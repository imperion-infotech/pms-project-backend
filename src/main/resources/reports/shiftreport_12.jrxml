<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="shiftreport" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="7f3a1b2c-4d5e-4f60-8a91-2b3c4d5e6f70">
	<property name="ireport.zoom" value="1.5"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
	<parameter name="hotelId" class="java.lang.Long"/>
	<parameter name="userId" class="java.lang.Long"/>
	<parameter name="fromDate" class="java.sql.Date"/>
	<parameter name="toDate" class="java.sql.Date"/>
	<parameter name="hotelName" class="java.lang.String"/>
	<parameter name="hotelAddress" class="java.lang.String"/>
	<parameter name="hotelEmail" class="java.lang.String"/>
	<parameter name="hotelPhone" class="java.lang.String"/>
	<parameter name="printedBy" class="java.lang.String"/>
	<query language="sql"><![CDATA[WITH shift_data AS (
    SELECT
        (COALESCE(pd.payment_date, usl.logout_time, usl.login_time)::date
            + CASE WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 6 THEN -1 ELSE 0 END
        )::text
        || '-'
        || CASE
             WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) >= 6  AND EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 14 THEN '1'
             WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) >= 14 AND EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 22 THEN '2'
             ELSE '3'
           END                                  AS shift_block_id,

        (COALESCE(pd.payment_date, usl.logout_time, usl.login_time)::date
            + CASE WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 6 THEN -1 ELSE 0 END
        )::date                                 AS shift_block_date,

        CASE
             WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) >= 6  AND EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 14 THEN 1
             WHEN EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) >= 14 AND EXTRACT(HOUR FROM COALESCE(pd.payment_date, usl.logout_time, usl.login_time)) < 22 THEN 2
             ELSE 3
        END                                      AS shift_block_no,

        pd.payment_date                         AS payment_date,
        gd.check_in_date::date                  AS date_in,
        gd.check_out_date::date                 AS date_out,
        rm.room_name                            AS room,
        COALESCE(NULLIF(TRIM(CONCAT(COALESCE(per.first_name, ''), ' ', COALESCE(per.last_name, ''))), ''), 'No Payments') AS guest_name,

        usl.user_id                             AS user_id,
        COALESCE(u.username, 'Unassigned')      AS user_name,
        usl.login_time                          AS login_time,
        usl.logout_time                         AS logout_time,

        CASE WHEN UPPER(pt.payment_type_name) = 'CASH' THEN pd.amount ELSE 0 END                 AS cash_amt_raw,
        CASE WHEN UPPER(pt.payment_type_name) NOT IN ('CASH','CHECK','CHEQUE') THEN pd.amount ELSE 0 END AS other_amt_raw,
        CASE WHEN UPPER(pt.payment_type_name) IN ('CHECK','CHEQUE') THEN pd.amount ELSE 0 END     AS bank_amt_raw,

        pd.amount                                                                       AS amount_raw,
        pt.payment_type_name                                                            AS payment_type,

        ROW_NUMBER() OVER (
            PARTITION BY COALESCE(pd.id::text, 'nopay-' || usl.id::text)
            ORDER BY usl.login_time DESC
        ) AS rn

    FROM user_session_log usl
    LEFT JOIN users u
        ON u.id = usl.user_id
       AND (u.is_deleted = false OR u.is_deleted IS NULL)
    LEFT JOIN payment_details pd
        ON pd.hotel_id = usl.hotel_id
       AND pd.payment_date >= usl.login_time
       AND pd.payment_date <= usl.logout_time
       AND (pd.is_deleted = false OR pd.is_deleted IS NULL)
       AND (pd.is_active = true OR pd.is_active IS NULL)
    LEFT JOIN payment_type pt ON pd.payment_type_id = pt.id
    LEFT JOIN guest_details gd ON pd.guest_details_id = gd.guest_details_id
    LEFT JOIN room_master rm ON gd.room_master_id = rm.id
    LEFT JOIN personal_details per ON gd.personal_details_id = per.id

    WHERE usl.hotel_id = $P{hotelId}
      AND (usl.is_deleted = false OR usl.is_deleted IS NULL)
      AND usl.logout_time IS NOT NULL
      AND date(usl.login_time)  <= $P{toDate}
      AND date(usl.logout_time) >= $P{fromDate}
      AND ($P{userId} IS NULL OR usl.user_id = $P{userId})
)
SELECT
    shift_block_id,
    shift_block_date,
    shift_block_no,
    payment_date,
    date_in,
    date_out,
    room,
    guest_name,
    user_id,
    user_name,
    login_time,
    logout_time,
    COALESCE(cash_amt_raw, 0)  AS cash_amt,
    COALESCE(other_amt_raw, 0) AS other_amt,
    COALESCE(bank_amt_raw, 0)  AS bank_amt,
    COALESCE(amount_raw, 0)    AS amount,
    payment_type
FROM shift_data
WHERE rn = 1
  AND shift_block_date BETWEEN $P{fromDate} AND $P{toDate}
  AND payment_date IS NOT NULL
ORDER BY user_name, shift_block_date, shift_block_no, guest_name, payment_date]]></query>
