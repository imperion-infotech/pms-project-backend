<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="daily_collection_report" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="7cc6cfa5-d8f3-489b-bc65-88cc581106cb">
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="468"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="521"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="HOTEL_NAME" class="java.lang.String"/>
	<parameter name="HOTEL_ADDRESS" class="java.lang.String"/>
	<parameter name="HOTEL_PHONE" class="java.lang.String"/>
	<parameter name="HOTEL_FAX" class="java.lang.String"/>
	<parameter name="HOTEL_EMAIL" class="java.lang.String"/>
	<parameter name="REPORT_DATE" class="java.lang.String"/>
	<parameter name="PRINTED_BY" class="java.lang.String"/>
	<parameter name="PRINTED_DATE" class="java.lang.String"/>
	<parameter name="TOTAL_CASH" class="java.lang.Double"/>
	<parameter name="TOTAL_CHECK" class="java.lang.Double"/>
	<parameter name="TOTAL_VISA" class="java.lang.Double"/>
	<parameter name="TOTAL_MC" class="java.lang.Double"/>
	<parameter name="TOTAL_AMEX" class="java.lang.Double"/>
	<parameter name="GRAND_TOTAL" class="java.lang.Double"/>
	<query language="SQL"><![CDATA[SELECT
    -- Desk user who processed the payment
    u.username                                          AS desk_user,

    -- Payment created date/time
    pd.created_on::date                                 AS pay_date,
    TO_CHAR(pd.created_on, 'HH24:MI')                  AS pay_time,

    -- Room number
    rm.room_name                                        AS room,

    -- Guest full name
    CONCAT(per.first_name, ' ', per.last_name)          AS guest_name,

    -- Check-in / Check-out dates
    gd.check_in_date::date                              AS date_in,
    gd.check_out_date::date                             AS date_out,

    -- Payment type name (Cash / Check / VISA / MC etc.)
    pt.payment_type_name                                AS payment_type,

    -- Card number masked (e.g. VI#x8579 / MC#x7774)
    CASE
        WHEN pt.payment_type_name NOT IN ('Cash','Check')
            THEN pt.payment_type_short_name
                 || '#x'
                 || RIGHT(pd.card_no, 4)
        ELSE pt.payment_type_name
    END                                                 AS payment_display,

    -- Amount collected
    pd.amount                                           AS amount,

    -- Flag markers
    CASE
        WHEN pd.payment_details_type = 'AUTHORIZED'         THEN '^'
        WHEN pd.payment_details_type = 'DELETED'            THEN '^^'
        WHEN pd.payment_details_type = 'ACCOUNT'            THEN '*'
        WHEN pd.payment_details_type = 'BUSINESS_COMMISSION'THEN '**'
        WHEN pd.payment_details_type = 'GROUP_AUTHORIZED'   THEN '*^'
        WHEN pd.payment_details_type = 'GROUP'              THEN '~'
        WHEN pd.payment_details_type = 'GROUP_DELETED'      THEN '~~'
        WHEN pd.payment_details_type = 'DEPOSIT'            THEN '!'
        ELSE ''
    END                                                 AS payment_flag,

    -- Payment category bucket for grouping sections
    CASE
        WHEN pt.payment_type_name = 'Cash'              THEN 'Cash'
        WHEN pt.payment_type_name = 'Check'             THEN 'Bank'
        ELSE 'Sale'
    END                                                 AS payment_category,

    -- Normalized card type: used by report variables for reliable totals
    CASE
        WHEN pt.payment_type_name = 'Cash'                   THEN 'Cash'
        WHEN pt.payment_type_name = 'Check'                  THEN 'Check'
        WHEN UPPER(pt.payment_type_name) LIKE '%VISA%'       THEN 'VISA'
        WHEN UPPER(pt.payment_type_name) LIKE '%MASTER%'
          OR UPPER(pt.payment_type_name) LIKE '%MC%'         THEN 'MC'
        WHEN UPPER(pt.payment_type_name) LIKE '%AMEX%'
          OR UPPER(pt.payment_type_name) LIKE '%AMERICAN%'   THEN 'AMEX'
        WHEN UPPER(pt.payment_type_name) LIKE '%DISCOVER%'   THEN 'DISC'
        WHEN UPPER(pt.payment_type_short_name) = 'CC'
          OR UPPER(pt.payment_type_name) LIKE '%CREDIT%'     THEN 'CC'
        WHEN UPPER(pt.payment_type_short_name) = 'DC'
          OR UPPER(pt.payment_type_name) LIKE '%DEBIT%'      THEN 'DC'
        ELSE UPPER(pt.payment_type_name)
    END                                                 AS card_type

FROM multi_motels_pms_db.payment_details pd

LEFT JOIN multi_motels_pms_db.payment_type pt
    ON pd.payment_type_id = pt.id

JOIN multi_motels_pms_db.guest_details gd
    ON pd.guest_details_id = gd.guest_details_id

LEFT JOIN multi_motels_pms_db.room_master rm
    ON gd.room_master_id = rm.id

LEFT JOIN multi_motels_pms_db.personal_details per
    ON gd.personal_details_id = per.id

LEFT JOIN multi_motels_pms_db.users u
    ON pd.created_by = u.id

WHERE
    pd.hotel_id     = 13
    AND pd.payment_date = '2026-05-27'         -- e.g. '2026-04-06'
    AND pd.is_deleted   = false
    AND pd.is_active    = true
    AND gd.is_deleted   = false

ORDER BY
    -- Sort: Cash first, Bank second, Sale third
    CASE
        WHEN pt.payment_type_name = 'Cash'  THEN 1
        WHEN pt.payment_type_name = 'Check' THEN 2
        ELSE 3
    END,
    -- Within each category sort by payment time
    pd.created_on
;
]]></query>
