	<query language="SQL"><![CDATA[select  a.id,a.guest_name,a.source,a.status,a.hotel_id,
a.created_by,a.created_on,b.hotel_name,c.room_name,d.username
from
multi_motels_pms_db.booking a,
multi_motels_pms_db.hotel b,
multi_motels_pms_db.room_master c,
multi_motels_pms_db.users d
where 
a.hotel_id=13 and
a.hotel_id=b.id and
a.room_master_id=c.id and
a.created_by=d.id]]></query>
