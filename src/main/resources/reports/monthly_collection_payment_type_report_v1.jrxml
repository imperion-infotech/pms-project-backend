<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="monthly_collection_payment_type_report" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="217dc932-aef7-4884-b4bf-753f2a7d3cc4">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="hotelId" class="java.lang.Long"/>
	<parameter name="fromDate" class="java.sql.Date"/>
	<parameter name="toDate" class="java.sql.Date"/>
	<parameter name="hotelName" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelAddress" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelPhone" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelFax" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelEmail" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="reportMonthLabel" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="printedBy" class="java.lang.String">
		<defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression>
	</parameter>
	<parameter name="printedOn" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    series.pay_day                                                          AS pay_day,
    COALESCE(SUM(CASE WHEN pt.payment_type_name = 'Cash'  THEN pd.amount END), 0) AS cash_amt,
    COALESCE(SUM(CASE WHEN pt.payment_type_name = 'Check'
                         OR pt.payment_type_name = 'Cheque' THEN pd.amount END), 0) AS check_amt,
	COALESCE(SUM(CASE WHEN UPPER(pt.payment_type_name) LIKE '%PAX%' THEN pd.amount END), 0) AS visa_amt,
    COALESCE(SUM(CASE WHEN UPPER(pt.payment_type_name) LIKE '%CREDIT%' THEN pd.amount END), 0) AS visa_amt,
    COALESCE(SUM(CASE WHEN UPPER(pt.payment_type_name) LIKE '%DEBIT%'
                         OR UPPER(pt.payment_type_name) LIKE '%CC%'   THEN pd.amount END), 0) AS mc_amt,
    COALESCE(SUM(CASE WHEN pt.payment_type_name IS NULL
                          OR pt.payment_type_name NOT IN ('Cash','Check','Cheque')
                         AND UPPER(pt.payment_type_name) NOT LIKE '%VISA%'
                         AND UPPER(pt.payment_type_name) NOT LIKE '%MASTER%'
                         AND UPPER(pt.payment_type_name) NOT LIKE '%MC%'
						 AND UPPER(pt.payment_type_name) NOT LIKE '%PAX%'
                     THEN pd.amount END), 0)                                 AS other_amt,
    COALESCE(SUM(pd.amount), 0)                                              AS total_payment
FROM (
    SELECT generate_series(
        CAST($P{fromDate} AS date),
        CAST($P{toDate}    AS date),
        INTERVAL '1 day'
    )::date AS pay_day
) series
LEFT JOIN multi_motels_pms_db.payment_details pd
    ON pd.payment_date::date = series.pay_day
   AND pd.hotel_id = $P{hotelId}
   AND (pd.is_deleted = false OR pd.is_deleted IS NULL)
   AND (pd.is_active  = true  OR pd.is_active  IS NULL)
LEFT JOIN multi_motels_pms_db.payment_type pt
    ON pd.payment_type_id = pt.id
GROUP BY series.pay_day
ORDER BY series.pay_day]]></query>
	<field name="pay_day" class="java.sql.Date"/>
	<field name="cash_amt" class="java.lang.Double"/>
	<field name="check_amt" class="java.lang.Double"/>
	<field name="visa_amt" class="java.lang.Double"/>
	<field name="mc_amt" class="java.lang.Double"/>
	<field name="other_amt" class="java.lang.Double"/>
	<field name="total_payment" class="java.lang.Double"/>
	<variable name="T_CASH" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{cash_amt}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_CHECK" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{check_amt}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_VISA" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{visa_amt}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_MC" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{mc_amt}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_OTHER" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{other_amt}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_TOTAL" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{total_payment}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
