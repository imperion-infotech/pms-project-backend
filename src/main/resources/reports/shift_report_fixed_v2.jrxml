    <!-- ==================== DETAIL ==================== -->
    <detail>
        <band height="14" splitType="Stretch">
            <element kind="textField" x="0"   y="0" width="55" height="13" fontName="DejaVu Sans" fontSize="7.0" hTextAlign="Center" blankWhenNull="true">
                <expression><![CDATA[
                    "CheckIn".equals($F{guest_status})    ? "C/I" :
                    "Check-In".equals($F{guest_status})   ? "C/I" :
                    "Check-Out".equals($F{guest_status})  ? "P-C/I" :
                    "Reservation".equals($F{guest_status})? "R/B" :
                    "Occupied".equals($F{guest_status})   ? "G/P" :
                    "Cancelled".equals($F{guest_status})  ? "Cancelled" :
                    ($F{guest_status} != null ? $F{guest_status} : "")
                ]]></expression>
            </element>
            <element kind="textField" x="55"  y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="MM/dd" hTextAlign="Center" blankWhenNull="true">
                <expression><![CDATA[$F{date_in}]]></expression>
