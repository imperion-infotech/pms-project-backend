            <element kind="textField" x="95"  y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="MM/dd" hTextAlign="Center" blankWhenNull="true">
                <expression><![CDATA[$F{date_out}]]></expression>
            </element>
            <element kind="textField" x="135" y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="M/d/yy h:mm a" hTextAlign="Center" blankWhenNull="true">
                <expression><![CDATA[$F{payment_date}]]></expression>
            </element>
            <element kind="textField" x="175" y="0" width="40" height="13" fontName="DejaVu Sans" fontSize="7.0" hTextAlign="Center" blankWhenNull="true">
                <expression><![CDATA[$F{room}]]></expression>
            </element>
            <element kind="textField" x="215" y="0" width="88" height="13" fontName="DejaVu Sans" fontSize="7.0" blankWhenNull="true">
                <expression><![CDATA[$F{guest_name}]]></expression>
            </element>
            <element kind="textField" x="303" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{cash_amt}]]></expression>
            </element>
            <element kind="textField" x="353" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{other_amt}]]></expression>
            </element>
            <element kind="textField" x="403" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{direct_discount}]]></expression>
            </element>
            <element kind="textField" x="453" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{deposit_amt}]]></expression>
            </element>
            <element kind="textField" x="503" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{billing_amt}]]></expression>
            </element>
            <element kind="textField" x="553" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{auth_to_sale}]]></expression>
            </element>
            <element kind="textField" x="603" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{bank_amt}]]></expression>
            </element>
            <element kind="textField" x="653" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{ccsale_amt}]]></expression>
            </element>
            <element kind="textField" x="703" y="0" width="50" height="13" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" blankWhenNull="true">
                <expression><![CDATA[$F{ccauth_amt}]]></expression>
            </element>
        </band>
    </detail>

    <!-- ==================== SUMMARY ==================== -->
    <summary height="120" splitType="Stretch">
        <!-- Grand Total row -->
        <element kind="line" x="0" y="0" width="802" height="1" forecolor="#000000"/>
        <element kind="staticText" x="0" y="4" width="100" height="13" fontName="DejaVu Sans" fontSize="9.0" bold="true">
            <text><![CDATA[Grand Total]]></text>
        </element>
        <element kind="textField" x="303" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_CASH}]]></expression>
        </element>
        <element kind="textField" x="353" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_OTHER}]]></expression>
        </element>
        <element kind="textField" x="403" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_DISCOUNT}]]></expression>
        </element>
        <element kind="textField" x="453" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_DEPOSIT}]]></expression>
        </element>
        <element kind="textField" x="503" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_BILLING}]]></expression>
        </element>
        <element kind="textField" x="553" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_AUTHSALE}]]></expression>
        </element>
        <element kind="textField" x="603" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_BANK}]]></expression>
        </element>
        <element kind="textField" x="653" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_CCSALE}]]></expression>
        </element>
        <element kind="textField" x="703" y="4" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_CCAUTH}]]></expression>
        </element>

        <!-- Other Payments breakdown box -->
        <element kind="staticText" x="0" y="25" width="120" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true">
            <text><![CDATA[Other Payments]]></text>
        </element>
        <element kind="staticText" x="0" y="40" width="100" height="11" fontName="DejaVu Sans" fontSize="7.0"><text><![CDATA[Complementary]]></text></element>
        <element kind="textField" x="100" y="40" width="60" height="11" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_COMPLEMENTARY}]]></expression>
        </element>
        <element kind="staticText" x="0" y="53" width="100" height="11" fontName="DejaVu Sans" fontSize="7.0"><text><![CDATA[BadDebts]]></text></element>
        <element kind="textField" x="100" y="53" width="60" height="11" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_BADDEBTS}]]></expression>
        </element>
        <element kind="staticText" x="0" y="66" width="100" height="11" fontName="DejaVu Sans" fontSize="7.0"><text><![CDATA[Others]]></text></element>
        <element kind="textField" x="100" y="66" width="60" height="11" fontName="DejaVu Sans" fontSize="7.0" pattern="#,##0.00" hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA[$V{G_OTHERS}]]></expression>
