        <element kind="staticText" x="0"   y="2" width="55" height="12" fontName="DejaVu Sans" fontSize="7.0" bold="true" hTextAlign="Center"><text><![CDATA[Status]]></text></element>
        <element kind="staticText" x="55"  y="2" width="40" height="12" fontName="DejaVu Sans" fontSize="7.0" bold="true" hTextAlign="Center"><text><![CDATA[Date In]]></text></element>
        <element kind="staticText" x="95"  y="2" width="40" height="12" fontName="DejaVu Sans" fontSize="7.0" bold="true" hTextAlign="Center"><text><![CDATA[Date Out]]></text></element>
