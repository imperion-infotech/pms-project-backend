        <element kind="textField" x="0" y="36" width="802" height="11" fontName="DejaVu Sans" fontSize="8.0">
            <expression><![CDATA["E-mail: " + $P{hotelEmail}]]></expression>
        </element>
        <element kind="line" x="0" y="50" width="802" height="1" forecolor="#AAAAAA"/>
        <element kind="textField" x="0" y="53" width="500" height="14" fontName="DejaVu Sans" fontSize="10.0" bold="true">
            <expression><![CDATA["Shift Report From " + $P{fromDate} + " To " + $P{toDate}]]></expression>
        </element>
        <element kind="line" x="0" y="68" width="802" height="1" forecolor="#AAAAAA"/>
    </title>

