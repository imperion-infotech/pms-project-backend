<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="shift_report" language="java"
    pageWidth="842" pageHeight="595" orientation="Landscape"
    columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- ==================== PARAMETERS ==================== -->
    <parameter name="hotelId"      class="java.lang.Long"/>
    <parameter name="fromDate"     class="java.sql.Date"/>
    <parameter name="toDate"       class="java.sql.Date"/>
    <parameter name="hotelName"    class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
    <parameter name="hotelAddress" class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
    <parameter name="hotelPhone"   class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
    <parameter name="hotelFax"     class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
    <parameter name="hotelEmail"   class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
    <parameter name="printedBy"    class="java.lang.String"><defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression></parameter>
    <parameter name="printedOn"    class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>

    <!-- ==================== QUERY ==================== -->
    <query language="SQL"><![CDATA[
SELECT
    -- Fixed 8-hour shift block: 06:00-14:00, 14:00-22:00, 22:00-06:00(+1)
    (pd.payment_date::date
        + CASE WHEN EXTRACT(HOUR FROM pd.payment_date) < 6 THEN -1 ELSE 0 END
    )::text
    || '-'
    || CASE
         WHEN EXTRACT(HOUR FROM pd.payment_date) >= 6  AND EXTRACT(HOUR FROM pd.payment_date) < 14 THEN '1'
         WHEN EXTRACT(HOUR FROM pd.payment_date) >= 14 AND EXTRACT(HOUR FROM pd.payment_date) < 22 THEN '2'
         ELSE '3'
       END                                  AS shift_block_id,

    (pd.payment_date::date
        + CASE WHEN EXTRACT(HOUR FROM pd.payment_date) < 6 THEN -1 ELSE 0 END
    )::date                                 AS shift_block_date,

    CASE
         WHEN EXTRACT(HOUR FROM pd.payment_date) >= 6  AND EXTRACT(HOUR FROM pd.payment_date) < 14 THEN 1
         WHEN EXTRACT(HOUR FROM pd.payment_date) >= 14 AND EXTRACT(HOUR FROM pd.payment_date) < 22 THEN 2
         ELSE 3
    END                                      AS shift_block_no,

    pd.payment_date                         AS payment_date,
    gd.guest_details_status                 AS guest_status,
    gd.check_in_date::date                  AS date_in,
    gd.check_out_date::date                 AS date_out,
    rm.room_name                            AS room,
    CONCAT(per.first_name, ' ', per.last_name) AS guest_name,

    -- Payment category breakdown
    CASE WHEN UPPER(pt.payment_type_name) = 'CASH' THEN pd.amount ELSE 0 END        AS cash_amt,
    CASE WHEN UPPER(pt.payment_type_name) NOT IN ('CASH','CHECK','CHEQUE')
         THEN pd.amount ELSE 0 END                                                  AS other_amt,
    rd.discount                                                                     AS direct_discount,
    0.0                                                                             AS deposit_amt,
    0.0                                                                             AS billing_amt,
    0.0                                                                             AS auth_to_sale,
    CASE WHEN UPPER(pt.payment_type_name) IN ('CHECK','CHEQUE')
         THEN pd.amount ELSE 0 END                                                  AS bank_amt,
    CASE WHEN UPPER(pt.payment_type_name) LIKE '%VISA%'
              OR UPPER(pt.payment_type_name) LIKE '%MASTER%'
              OR UPPER(pt.payment_type_name) LIKE '%AMEX%'
              OR UPPER(pt.payment_type_short_name) = 'CC'
         THEN pd.amount ELSE 0 END                                                  AS ccsale_amt,
    0.0                                                                             AS ccauth_amt,

    pd.amount                                                                       AS amount,
    pt.payment_type_name                                                            AS payment_type

FROM multi_motels_pms_db.payment_details pd

LEFT JOIN multi_motels_pms_db.payment_type pt
    ON pd.payment_type_id = pt.id

LEFT JOIN multi_motels_pms_db.guest_details gd
    ON pd.guest_details_id = gd.guest_details_id

LEFT JOIN multi_motels_pms_db.room_master rm
    ON gd.room_master_id = rm.id

LEFT JOIN multi_motels_pms_db.personal_details per
    ON gd.personal_details_id = per.id

LEFT JOIN multi_motels_pms_db.rent_details rd
    ON rd.personal_details_id = gd.personal_details_id

WHERE pd.hotel_id = $P{hotelId}
  AND pd.payment_date::date BETWEEN $P{fromDate} AND $P{toDate}
  AND (pd.is_deleted = false OR pd.is_deleted IS NULL)
  AND (pd.is_active = true OR pd.is_active IS NULL)

ORDER BY shift_block_date, shift_block_no, pd.payment_date
    ]]></query>

    <!-- ==================== FIELDS ==================== -->
    <field name="shift_block_id"      class="java.lang.String"/>
    <field name="shift_block_date"    class="java.sql.Date"/>
    <field name="shift_block_no"      class="java.lang.Integer"/>
    <field name="payment_date"        class="java.sql.Timestamp"/>
    <field name="guest_status"        class="java.lang.String"/>
    <field name="date_in"             class="java.sql.Date"/>
    <field name="date_out"            class="java.sql.Date"/>
    <field name="room"                class="java.lang.String"/>
    <field name="guest_name"          class="java.lang.String"/>
    <field name="cash_amt"            class="java.lang.Double"/>
    <field name="other_amt"           class="java.lang.Double"/>
    <field name="direct_discount"     class="java.lang.Double"/>
    <field name="deposit_amt"         class="java.lang.Double"/>
    <field name="billing_amt"         class="java.lang.Double"/>
    <field name="auth_to_sale"        class="java.lang.Double"/>
    <field name="bank_amt"            class="java.lang.Double"/>
    <field name="ccsale_amt"          class="java.lang.Double"/>
    <field name="ccauth_amt"          class="java.lang.Double"/>
    <field name="amount"              class="java.lang.Double"/>
    <field name="payment_type"        class="java.lang.String"/>

    <group name="shift_group">
        <expression><![CDATA[$F{shift_block_id}]]></expression>
        <groupHeader>
            <band height="18" splitType="Stretch">
                <element kind="textField" x="0" y="2" width="400" height="14"
                    fontName="DejaVu Sans" fontSize="9.0" bold="true">
                    <expression><![CDATA[
                        "Shift Time " +
                        new java.text.SimpleDateFormat("M/d/yyyy").format($F{shift_block_date}) + " " +
                        ($F{shift_block_no} == 1 ? "6:00 AM - 2:00 PM" :
                         $F{shift_block_no} == 2 ? "2:00 PM - 10:00 PM" :
                                                    "10:00 PM - 6:00 AM")
                    ]]></expression>
                </element>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="16" splitType="Stretch">
                <element kind="rectangle" x="0" y="0" width="802" height="15"
                    forecolor="#E8E8E8" backcolor="#E8E8E8" mode="Opaque"/>
                <element kind="staticText" x="263" y="1" width="40" height="13"
                    fontName="DejaVu Sans" fontSize="8.0" bold="true">
                    <text><![CDATA[Total]]></text>
                </element>
                <element kind="textField" x="303" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_CASH}]]></expression>
                </element>
                <element kind="textField" x="353" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_OTHER}]]></expression>
                </element>
                <element kind="textField" x="403" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_DISCOUNT}]]></expression>
                </element>
                <element kind="textField" x="453" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_DEPOSIT}]]></expression>
                </element>
                <element kind="textField" x="503" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_BILLING}]]></expression>
                </element>
                <element kind="textField" x="553" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_AUTHSALE}]]></expression>
                </element>
                <element kind="textField" x="603" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_BANK}]]></expression>
                </element>
                <element kind="textField" x="653" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_CCSALE}]]></expression>
                </element>
                <element kind="textField" x="703" y="1" width="50" height="13" fontName="DejaVu Sans" fontSize="8.0" bold="true" pattern="#,##0.00" hTextAlign="Right">
                    <expression><![CDATA[$V{S_CCAUTH}]]></expression>
                </element>
            </band>
        </groupFooter>
    </group>

    <!-- ==================== VARIABLES: grand totals ==================== -->
    <variable name="G_CASH"     class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{cash_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_OTHER"    class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{other_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_DISCOUNT" class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{direct_discount}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_DEPOSIT"  class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{deposit_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_BILLING"  class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{billing_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_AUTHSALE" class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{auth_to_sale}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_BANK"     class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{bank_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_CCSALE"   class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{ccsale_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="G_CCAUTH"   class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{ccauth_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>

    <!-- Other payments breakdown (legend section) -->
    <!-- TODO: rewire once new payment_details_type replacement field is available -->
    <variable name="G_COMPLEMENTARY" class="java.lang.Double" calculation="Sum">
        <expression><![CDATA[0.0]]></expression>
        <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
    </variable>
    <variable name="G_BADDEBTS" class="java.lang.Double" calculation="Sum">
        <expression><![CDATA[0.0]]></expression>
        <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
    </variable>
    <variable name="G_OTHERS" class="java.lang.Double" calculation="Sum">
        <expression><![CDATA[0.0]]></expression>
        <initialValueExpression><![CDATA[0.0]]></initialValueExpression>
    </variable>

    <!-- per-shift subtotal variables -->
    <variable name="S_CASH"     class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{cash_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_OTHER"    class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{other_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_DISCOUNT" class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{direct_discount}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_DEPOSIT"  class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{deposit_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_BILLING"  class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{billing_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_AUTHSALE" class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{auth_to_sale}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_BANK"     class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{bank_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_CCSALE"   class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{ccsale_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>
    <variable name="S_CCAUTH"   class="java.lang.Double" resetType="Group" resetGroup="shift_group" calculation="Sum"><expression><![CDATA[$F{ccauth_amt}]]></expression><initialValueExpression><![CDATA[0.0]]></initialValueExpression></variable>

    <background splitType="Stretch"/>

    <!-- ==================== TITLE ==================== -->
    <title height="78" splitType="Stretch">
        <element kind="textField" x="0" y="0" width="802" height="14" fontName="DejaVu Sans" fontSize="11.0" bold="true">
            <expression><![CDATA[$P{hotelName}]]></expression>
        </element>
        <element kind="textField" x="0" y="14" width="802" height="11" fontName="DejaVu Sans" fontSize="8.0">
