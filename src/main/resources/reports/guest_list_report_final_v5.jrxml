<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="guest_list_report" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f1ca02e3-75a8-4d09-bacb-b817b62fd6c0">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="HOTEL_ID" class="java.lang.Long">
		<defaultValueExpression><![CDATA[13L]]></defaultValueExpression>
	</parameter>
	<parameter name="REPORT_DATE" class="java.sql.Date">
		<defaultValueExpression><![CDATA[new java.sql.Date(System.currentTimeMillis())]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_NAME" class="java.lang.String">
		<defaultValueExpression><![CDATA["Hotel"]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_ADDRESS" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_PHONE" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_FAX" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="HOTEL_EMAIL" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="PRINTED_BY" class="java.lang.String">
		<defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression>
	</parameter>
	<parameter name="PRINTED_DATE" class="java.lang.String">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("M/d/yyyy hh:mm a").format(new java.util.Date())]]></defaultValueExpression>
	</parameter>
	<parameter name="FROM_DATE" class="java.sql.Date"/>
	<parameter name="TO_DATE" class="java.sql.Date"/>
	<parameter name="REPORT_DATE_STR" class="java.lang.String"/>
	<query language="SQL"><![CDATA[
        SELECT * FROM (
        SELECT DISTINCT ON (gd.guest_details_id)
            rm.room_name                                        AS room,
            CONCAT(per.first_name, ' ', per.last_name)         AS guest_name,
            per.address                                         AS address,
            per.phone                                           AS phone,
            gd.check_in_date::date                             AS check_in_date,
            gd.check_out_date::date                            AS check_out_date,
            gd.guest_details_status                            AS guest_status,
            COALESCE(dt.document_type_name, '')                AS doc_type,
            COALESCE(dd.document_number, '')                   AS doc_number,
            CASE
                WHEN dd.document_number IS NOT NULL AND dt.document_type_name IS NOT NULL
                    THEN UPPER(dt.document_type_name) || ' : ' ||
                         CASE
                             WHEN UPPER(dt.document_type_name) LIKE '%CARD%'
                                 THEN 'XXXX-XXXX-XXXX-' || RIGHT(dd.document_number, 4)
                             ELSE dd.document_number
                         END
                ELSE '--N/A--'
            END                                                AS id_info,
            per.birth_date::date                            AS birth_date,
            per.nationality                                     AS nationality,
            CASE
                WHEN gd.guest_details_status = 'Check-In'    THEN 1
                WHEN gd.guest_details_status = 'Reservation' THEN 2
                WHEN gd.guest_details_status = 'Cancelled'   THEN 3
                WHEN gd.guest_details_status = 'Check-Out'   THEN 4
                ELSE 5
            END                                                AS status_sort
        FROM multi_motels_pms_db.guest_details gd
        JOIN multi_motels_pms_db.personal_details per
            ON gd.personal_details_id = per.id
        LEFT JOIN multi_motels_pms_db.room_master rm
            ON gd.room_master_id = rm.id
        LEFT JOIN multi_motels_pms_db.document_details dd
            ON dd.personal_details_id = gd.personal_details_id
           AND (dd.is_deleted = false OR dd.is_deleted IS NULL)
           AND (dd.is_active = true OR dd.is_active IS NULL)
        LEFT JOIN multi_motels_pms_db.document_type dt
            ON dd.document_type_id = dt.id
        WHERE
            gd.hotel_id = $P{HOTEL_ID}
           AND gd.check_in_date::date BETWEEN $P{FROM_DATE} AND $P{TO_DATE}
            AND (gd.is_deleted = false OR gd.is_deleted IS NULL)
            AND (gd.is_active = true OR gd.is_active IS NULL)
            AND (per.is_deleted = false OR per.is_deleted IS NULL)
        ORDER BY
            gd.guest_details_id,
            status_sort,
            rm.room_name
        ) sub
        ORDER BY
            status_sort,
            room
    ]]></query>
	<field name="room" class="java.lang.String"/>
	<field name="guest_name" class="java.lang.String"/>
	<field name="address" class="java.lang.String"/>
	<field name="phone" class="java.lang.String"/>
	<field name="check_in_date" class="java.sql.Date"/>
	<field name="check_out_date" class="java.sql.Date"/>
	<field name="guest_status" class="java.lang.String"/>
	<field name="doc_type" class="java.lang.String"/>
	<field name="doc_number" class="java.lang.String"/>
	<field name="id_info" class="java.lang.String"/>
	<field name="birth_date" class="java.sql.Date"/>
	<field name="nationality" class="java.lang.String"/>
	<field name="status_sort" class="java.lang.Integer"/>
	<variable name="V_TOTAL_GUESTS" calculation="Count" class="java.lang.Integer">
		<expression><![CDATA[$F{guest_name}]]></expression>
	</variable>
	<group name="status_group">
		<expression><![CDATA[$F{status_sort}]]></expression>
		<groupHeader>
			<band height="18" splitType="Stretch">
				<element kind="rectangle" uuid="aabb1122-0000-0000-0000-000000000001" mode="Opaque" x="0" y="0" width="802" height="16" forecolor="#555555" backcolor="#555555"/>
				<element kind="textField" uuid="aabb1122-0000-0000-0000-000000000002" x="3" y="1" width="600" height="14" forecolor="#FFFFFF" fontName="DejaVu Sans" fontSize="9.0" bold="true" vTextAlign="Middle">
					<expression><![CDATA[
						"Check-In".equals($F{guest_status})    ? "Check-In" :
						"Reservation".equals($F{guest_status}) ? "Reservation" :
						"Cancelled".equals($F{guest_status})   ? "Cancelled" :
						"Check-Out".equals($F{guest_status})   ? "Check-Out" :
						($F{guest_status} != null ? $F{guest_status} : "Other")
					]]></expression>
				</element>
			</band>
		</groupHeader>
		<groupFooter>
			<band splitType="Stretch"/>
		</groupFooter>
	</group>
