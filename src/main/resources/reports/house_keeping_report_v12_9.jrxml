			<expression><![CDATA[$P{hotelName}]]></expression>
		</element>
		<element kind="textField" uuid="a1a7ae00-9259-49ad-bfed-9e3546d299b1" x="0" y="22" width="782" height="14" fontName="DejaVu Sans" fontSize="11.0" blankWhenNull="true">
			<expression><![CDATA[java.util.stream.Stream.of($P{hotelAddress}, $P{hotelCity}, $P{hotelState}, $P{hotelZipcode}, $P{hotelCountry})
                .filter(s -> s != null && !s.trim().isEmpty())
                .collect(java.util.stream.Collectors.joining(", "))]]></expression>
		</element>
		<element kind="textField" uuid="a9c89ec4-4b6f-4613-8fd5-148c8e374595" x="0" y="36" width="782" height="18" fontName="DejaVu Sans" fontSize="11.0" vTextAlign="Middle">
