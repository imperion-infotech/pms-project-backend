		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="T_TOTAL" calculation="Sum" class="java.lang.Double">
		<expression><![CDATA[$F{total_payment}]]></expression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
