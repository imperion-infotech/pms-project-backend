	</parameter>
	<parameter name="hotelCountry" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelEmail" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="buildingId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="floorId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[null]]></defaultValueExpression>
	</parameter>
	<parameter name="printedBy" class="java.lang.String">
		<defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression>
	</parameter>
	<parameter name="printedOn" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelPhone" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[
SELECT
    ROW_NUMBER() OVER (
        PARTITION BY b.building_id, f.floor_id
        ORDER BY rm.room_name
    )                                   AS sr_no,

    rm.room_name                        AS room,
    rt.room_type_name                   AS room_type,
    rs.room_status_name                 AS status,

    b.building_name                     AS building_name,
    f.floor_name                        AS floor_name

FROM room_master rm

LEFT JOIN floor    f  ON f.floor_id    = rm.floor_id
LEFT JOIN building b  ON b.building_id = rm.building_id
LEFT JOIN hotel    h  ON h.id          = rm.hotel_id
LEFT JOIN room_type   rt ON rt.room_type_id   = rm.room_type_id
LEFT JOIN room_status rs ON rs.room_status_id = rm.room_status_id

WHERE rm.hotel_id   = $P{hotelId}
  AND rm.is_deleted = false
  AND rm.is_active  = true
  --AND rm.updated_on::date = CURRENT_DATE
  AND ($P{buildingId} IS NULL OR rm.building_id = $P{buildingId})
  AND ($P{floorId}    IS NULL OR rm.floor_id    = $P{floorId})

ORDER BY b.building_name, f.floor_name, rm.room_name
]]></query>
	<field name="sr_no" class="java.lang.Long"/>
	<field name="room" class="java.lang.String"/>
	<field name="room_type" class="java.lang.String"/>
	<field name="status" class="java.lang.String"/>
	<field name="building_name" class="java.lang.String"/>
	<field name="floor_name" class="java.lang.String"/>
	<group name="FloorGroup">
		<expression><![CDATA[($F{building_name} != null ? $F{building_name} : "Unassigned Building") + " - " + ($F{floor_name} != null ? $F{floor_name} : "Unassigned Floor")]]></expression>
		<groupHeader>
