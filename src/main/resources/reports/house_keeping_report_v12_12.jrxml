<jasperReport name="house_keeping_report" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="ca513024-9916-4517-b70c-e4cd29333b9b">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter (2)"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="hotelId" class="java.lang.Long">
		<defaultValueExpression><![CDATA[0L]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelName" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="hotelAddress" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
