					<expression><![CDATA[($F{building_name} != null ? $F{building_name} : "No Building") + "  /  " + ($F{floor_name} != null ? $F{floor_name} : "No Floor")]]></expression>
				</element>
				<element kind="line" uuid="d2e3f4a5-b6c7-4890-1234-456789012345" x="0" y="26" width="782" height="1" forecolor="#AAAAAA"/>
